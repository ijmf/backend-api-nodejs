          "name": "Deletar Recomendation ID",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status 204 - Deletado com sucesso\", function () {\r",
                  "    pm.response.to.have.status(204);\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/recommendation/{{recommendationId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
